{
  "query": "\nSELECT \n  u.name,\n  COUNT(*) as total_this_week,\n  SUM(CASE WHEN l.sentAt >= '2026-06-08 00:00:00' THEN 1 ELSE 0 END) as sent_today,\n  SUM(CASE WHEN l.status = 'sent' THEN 1 ELSE 0 END) as successful,\n  MIN(l.sentAt) as first_send,\n  MAX(l.sentAt) as last_send\nFROM userEmailSendLog l\nJOIN users u ON u.id = l.userId\nWHERE l.weekKey = '2026W23'\n  AND l.digestType = 'monday'\nGROUP BY u.id, u.name\nORDER BY total_this_week DESC;\n",
