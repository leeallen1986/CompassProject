{
  "query": "SELECT \n  p.id, p.name, p.priority, p.sector, p.projectState,\n  DATE(p.createdAt) AS addedDate,\n  COUNT(c.id) AS totalContacts,\n  SUM(CASE WHEN c.contactTrustTier = 'send_ready' THEN 1 ELSE 0 END) AS sendReady,\n  SUM(CASE WHEN c.contactTrustTier = 'named_unverified' THEN 1 ELSE 0 END) AS namedUnverified,\n  SUM(CASE WHEN c.contactTrustTier = 'llm_inferred' THEN 1 ELSE 0 END) AS llmInferred\nFROM projects p\nLEFT JOIN contacts c ON c.project = p.name\nWHERE p.createdAt >= '2026-05-12 00:00:00'\n  AND p.suppressed = 0\n  AND p.priority IN ('hot', 'warm')\nGROUP BY p.id\nORDER BY sendReady DESC, namedUnverified DESC, p.priority ASC, p.createdAt ASC;",
  "command": "mysql --batch --raw --column-names --default-character-set=utf8mb4 --host gateway02.us-east-1.prod.aws.tidbcloud.com --port 4000 --user HWMKhVWm4R1gayY.38561a93bc5c --database 3SMu786VMCWdCnmNSx6pxw --execute SELECT \n  p.id, p.name, p.priority, p.sector, p.projectState,\n  DATE(p.createdAt) AS addedDate,\n  COUNT(c.id) AS totalContacts,\n  SUM(CASE WHEN c.contactTrustTier = 'send_ready' THEN 1 ELSE 0 END) AS sendReady,\n  SUM(CASE WHEN c.contactTrustTier = 'named_unverified' THEN 1 ELSE 0 END) AS namedUnverified,\n  SUM(CASE WHEN c.contactTrustTier = 'llm_inferred' THEN 1 ELSE 0 END) AS llmInferred\nFROM projects p\nLEFT JOIN contacts c ON c.project = p.name\nWHERE p.createdAt >= '2026-05-12 00:00:00'\n  AND p.suppressed = 0\n  AND p.priority IN ('hot', 'warm')\nGROUP BY p.id\nORDER BY sendReady DESC, namedUnverified DESC, p.priority ASC, p.createdAt ASC;",
